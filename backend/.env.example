# Copy to .env and fill in real values for your environment.

POSTGRES_DB=clientpulse
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Sync driver (psycopg2) — used by SQLAlchemy + the seed script.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/clientpulse

# Comma-separated browser origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# --- OpenAI (agent layer) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5
OPENAI_MODEL_MINI=gpt-5-mini
OPENAI_VECTOR_STORE_ID=
